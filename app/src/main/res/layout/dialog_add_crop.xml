<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="20dp"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Market Price"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textColor="@color/bluish_black"
        android:textSize="18dp"
        />

    <EditText android:id="@+id/etCrop"
        android:hint="Crop Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText android:id="@+id/etMin"
        android:hint="Min Price"
        android:inputType="number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText android:id="@+id/etMax"
        android:hint="Max Price"
        android:inputType="number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText android:id="@+id/etMandi"
        android:hint="Mandi Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>



    <Button android:id="@+id/btnSave"
        android:text="Save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
